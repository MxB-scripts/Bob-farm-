-- === ЛОГИКА ФАРМА ===
local function farm()
    while _G.AutoFarm do
        local char = player.Character or player.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")

        statusLabel.Text = "Status: Walking to Portal..."
        
        local isTeleported = false
        local lastPos = hrp.Position 
        
        -- Цикл ходьбы к порталу
        while _G.AutoFarm and not isTeleported do
            hum:MoveTo(portalPos)
            task.wait(0.1)
            
            -- Проверка на смерть/пропажу перса
            if not char or not char:FindFirstChild("HumanoidRootPart") or hum.Health <= 0 then
                break
            end
            
            local currentPos = hrp.Position
            -- Вычисляем, на какое расстояние переместился игрок за эти 0.1 сек
            local moveDist = (currentPos - lastPos).Magnitude
            
            -- Если за 0.1 сек расстояние изменилось больше чем на 30 - это ТЕЛЕПОРТ
            if moveDist > 30 then
                isTeleported = true
                -- Принудительно заставляем персонажа остановиться
                hum:MoveTo(currentPos) 
                break
            end
            
            lastPos = currentPos 
            
            -- Прыгаем, если застряли
            if hrp.Velocity.Magnitude < 1 then hum.Jump = true end
        end

        -- Если скрипт выключили во время бега - выходим
        if not _G.AutoFarm then break end

        -- Если цикл прервался из-за телепорта:
        if isTeleported then
            statusLabel.Text = "Status: Teleported! Using E..."
            task.wait(0.5) 
            
            -- Жмем E
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

            task.wait(0.5) 

            -- Ресет
            statusLabel.Text = "Status: Resetting..."
            if char:FindFirstChild("Head") then
                char:BreakJoints()
            end
        end

        -- Ждем нового перса
        player.CharacterAdded:Wait()
        task.wait(1.5) 
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    _G.AutoFarm = not _G.AutoFarm
    if _G.AutoFarm then
        toggleBtn.Text = "STOP FARM"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        task.spawn(farm)
    else
        toggleBtn.Text = "START FARM"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        statusLabel.Text = "Status: OFF"
    end
end)
